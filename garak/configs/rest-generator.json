{
  "rest": {
    "RestGenerator": {
      "name": "clinical-ai-gateway",
      "uri": "http://localhost:8000/query",
      "method": "post",
      "headers": {
        "Content-Type": "application/json"
      },
      "req_template_json_object": {
        "query": "$INPUT",
        "user_id": "garak-scanner",
        "session_id": "garak-session"
      },
      "response_json": true,
      "response_json_field": "$.answer",
      "request_timeout": 120,
      "ratelimit_codes": [429],
      "skip_codes": [400]
    }
  }
}
