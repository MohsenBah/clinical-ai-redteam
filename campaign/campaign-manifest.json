      "phase": "baseline",
      "cai_id": null,
      "action": "query",
      "description": "Benign clinical RAG query",
      "payload": "payloads/baseline/normal-clinical.json",
      "expect_http": [200],
      "expect_decision": "allowed",
      "expect_rules": [],
      "reject_rules": ["100100", "100101", "100102", "100300"],
      "validation_case": "allowed-normal-clinical"
    },
    {
      "id": "cai-004-baseline",
      "phase": "adversarial",
      "cai_id": "CAI-004",
      "action": "query",
