      "expect_decision": "blocked",
      "expect_rules": ["100100", "100102"],
      "reject_rules": ["100300"],
      "validation_case": "blocked-instruction-override"
    },
    {
      "id": "cai-002",
      "phase": "adversarial",
      "cai_id": "CAI-002",
