{
  "version": 1,
  "description": "MedSecLab red team campaign steps with expected gateway and Wazuh outcomes",
  "steps": [
    {
      "id": "a1-health",
      "phase": "baseline",
      "cai_id": null,
      "action": "health",
      "description": "Gateway health check"
    },
    {
      "id": "a2-clear-data",
      "phase": "baseline",
      "cai_id": null,
      "action": "clear_data",
      "description": "Clear vector database"
    },
    {
      "id": "a3-failed-ingest",
      "phase": "baseline",
      "cai_id": null,
      "action": "ingest",
      "description": "Failed ingestion audit event",
      "ingest_body": { "data_path": "/app/data/missing_file.csv" }
    },
    {
      "id": "a4-success-ingest",
      "phase": "baseline",
      "cai_id": null,
      "action": "ingest",
      "description": "Ingest synthetic patients",
      "ingest_body": {
        "data_path": "/app/data/synthetic_patients.json",
        "clear_existing": true
      }
    },
    {
