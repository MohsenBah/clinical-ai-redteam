      "payload": "payloads/admin-abuse/cai-004-baseline.json",
      "expect_http": [200],
      "expect_decision": "allowed",
      "expect_rules": [],
      "reject_rules": ["100100", "100102"],
      "sub_variant": "baseline"
    },
    {
      "id": "cai-001",
      "phase": "adversarial",
      "cai_id": "CAI-001",
      "action": "query",
      "description": "Instruction override",
      "payload": "payloads/prompt-injection/cai-001.json",
